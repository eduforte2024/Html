<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Pokedex Insana</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial;
      text-align: center;
      background: #1e1e2f;
      color: white;
      transition: 0.3s;
    }

    .hidden {
      display: none;
    }

    .container {
      padding: 20px;
    }

    button {
      padding: 10px;
      border-radius: 8px;
      margin: 5px;
      background: #444;
      color: white;
      border: none;
      cursor: pointer;
    }

    input {
      padding: 10px;
      border-radius: 8px;
      border: none;
    }

    img {
      width: 150px;
    }
  </style>
</head>

<body>

<h1>POKÉDEX</h1>

<!-- MENU -->
<div>
  <button onclick="showPage('main')">🏠 Home</button>
  <button onclick="showPage('favPage')">⭐ Favoritos</button>
  <button onclick="showPage('logPage')">📝 Histórico</button>
  <button onclick="resetApp()">🔄 Reiniciar</button>
</div>

<!-- HOME -->
<div id="main" class="container">

  <input id="search" placeholder="Buscar Pokémon">
  <button onclick="searchPokemon()">Buscar</button>

  <p id="loading"></p>

  <div>
    <img id="img">
    <h2 id="name"></h2>
    <p id="id"></p>
    <p id="type"></p>
  </div>

  <div>
    <button onclick="prev()">◀</button>
    <button onclick="home()">🏠</button>
    <button onclick="next()">▶</button>
    <button onclick="random()">🎲</button>
    <button onclick="favorite()">⭐</button>
  </div>

</div>

<!-- FAVORITOS -->
<div id="favPage" class="container hidden">
  <h2>⭐ Favoritos</h2>
  <div id="favorites"></div>
</div>

<!-- HISTÓRICO -->
<div id="logPage" class="container hidden">
  <h2>📝 Histórico</h2>
  <div id="logs"></div>
</div>

<script>
let id = 1;
let favorites = [];
let logs = [];

const colors = {
  fire: "#ff6b6b",
  water: "#3498db",
  grass: "#2ecc71",
  electric: "#f1c40f",
  psychic: "#9b59b6",
  normal: "#95a5a6"
};

// 🔄 trocar páginas
function showPage(page) {
  document.getElementById("main").classList.add("hidden");
  document.getElementById("favPage").classList.add("hidden");
  document.getElementById("logPage").classList.add("hidden");

  document.getElementById(page).classList.remove("hidden");
}

// 📝 logs
function addLog(msg) {
  logs.push(msg);

  document.getElementById("logs").innerHTML =
    logs.map(l => `<p>${l}</p>`).join("");
}

// 🔥 fetch
async function fetchPokemon(value) {
  try {
    document.getElementById("loading").innerText = "Carregando...";

    const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${value}`);
    const data = await res.json();

    id = data.id;

    document.getElementById("name").innerText = data.name.toUpperCase();
    document.getElementById("img").src = data.sprites.front_default;
    document.getElementById("id").innerText = "ID: " + data.id;

    const t1 = data.types[0].type.name;
    const t2 = data.types[1]?.type.name;

    document.getElementById("type").innerText =
      t1 + (t2 ? " / " + t2 : "");

    document.body.style.background = colors[t1] || "#1e1e2f";

    addLog("Carregado: " + data.name);

  } catch {
    alert("Pokémon não encontrado");
    addLog("Erro na busca");
  } finally {
    document.getElementById("loading").innerText = "";
  }
}

// navegação
function next() {
  id++;
  fetchPokemon(id);
}

function prev() {
  if (id > 1) {
    id--;
    fetchPokemon(id);
  }
}

function home() {
  id = 1;
  fetchPokemon(id);
}

function random() {
  id = Math.floor(Math.random() * 1000) + 1;
  fetchPokemon(id);
}

// busca
function searchPokemon() {
  const value = document.getElementById("search").value.toLowerCase();
  if (value) {
    fetchPokemon(value);
    addLog("Busca: " + value);
  }
}

// ⭐ favoritos (clicáveis)
function favorite() {
  const name = document.getElementById("name").innerText;

  if (!favorites.includes(name)) {
    favorites.push(name);
    addLog("Favorito: " + name);
  }

  renderFavorites();
}

function renderFavorites() {
  const el = document.getElementById("favorites");

  if (favorites.length === 0) {
    el.innerText = "Nenhum favorito";
    return;
  }

  el.innerHTML = favorites.map(f =>
    `<button onclick="fetchPokemon('${f.toLowerCase()}'); showPage('main')">${f}</button>`
  ).join("");
}

// 🔄 reiniciar app
function resetApp() {
  if (confirm("Deseja reiniciar o app?")) {
    id = 1;
    favorites = [];
    logs = [];
    document.getElementById("logs").innerHTML = "";
    document.getElementById("favorites").innerHTML = "";
    fetchPokemon(1);
    showPage("main");
  }
}

// iniciar
fetchPokemon(1);
</script>

</body>
</html>